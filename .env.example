# Self-Evolver environment configuration.
# Copy to `.env` and fill in the values you need. Every variable below is read
# by the code; unset variables fall back to the defaults shown here.

# --- Worker LLM (Inspector / PatchGenerator / Verifier / Judge) ---------------
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
MAX_TOKENS_PER_CALL=4096
TEMPERATURE=0.0

# --- High-level Controller LLM (optional; --controller-mode llm) --------------
# Point these at a vLLM-served checkpoint to use a trained controller.
# They default to the OPENAI_* values above when unset.
CONTROLLER_API_KEY=token-or-empty
CONTROLLER_MODEL=Qwen/Qwen2.5-1.5B-Instruct
CONTROLLER_BASE_URL=http://127.0.0.1:8000/v1
CONTROLLER_MAX_TOKENS=1024
CONTROLLER_TEMPERATURE=0.2

# --- Repair loop / worker budgets ---------------------------------------------
MAX_ITERATIONS=3
AGENT_TIMEOUT=300
INSPECTOR_MAX_TOOL_CALLS=8
INSPECTOR_READ_MAX_LINES=400
INSPECTOR_READ_MAX_CHARS=20000

# --- Environment / logging ----------------------------------------------------
WORKSPACE_DIR=./workspace
LOG_LEVEL=INFO

# --- Benchmark data and container evaluation ----------------------------------
# Local SWE-bench save_to_disk root (default: <repo>/benchmarks).
SWEBENCH_DATA_DIR=./benchmarks
# Per-instance eval timeout in seconds for the container backends.
SWEBENCH_EVAL_TIMEOUT=1800
# Apptainer SIF cache (default: ~/.cache/self_evolver/sif).
SIF_CACHE_DIR=~/.cache/self_evolver/sif
# Official Docker-harness per-instance timeout (only used with a docker engine).
DOCKER_TIMEOUT=600

# --- Online RL reward (src/reward/online_reward.py:compute_score) -------------
# Container engine for official-semantics grading during GRPO rollouts.
SELF_EVOLVER_TEST_BACKEND=apptainer
SELF_EVOLVER_REWARD_CONFIG=configs/reward_config.yaml
SELF_EVOLVER_ROLLOUT_JSONL=benchmark_results/online_rollouts.jsonl
SELF_EVOLVER_REWARD_WORKSPACE=./workspace/online_reward
SELF_EVOLVER_ENABLE_SKILL_EVOLUTION=0
SELF_EVOLVER_MAX_ITERATIONS=3

# --- Failure-cluster embeddings (optional; lexical fallback if unset) ---------
# When EMBEDDING_MODEL is set the Reflector clusters hard cases by embedding
# cosine similarity via an OpenAI-compatible endpoint; otherwise it uses a
# lexical similarity fallback (no network).
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
